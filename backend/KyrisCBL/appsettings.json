{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/applog-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Properties": {
      "Application": "SupportChatbotAPI"
    }
  },
  "Logging": {
    "EscalationLogPath": "Logs/EscalationLogs",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY_HERE",
    "ModelName": "text-embedding-3-small"
  },
  "ConnectionStrings": {
    "Default": "server=YOUR_DB_SERVER;database=YOUR_DB_NAME;uid=YOUR_DB_USER;pwd=YOUR_DB_PASSWORD;TrustServerCertificate=True;Connect Timeout=120;"
  }
}
